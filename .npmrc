# pnpm 10+ ignores dependency postinstall scripts by default. The equivalent
# settings in pnpm-workspace.yaml and package.json's "pnpm" field weren't
# honored on Hostinger's build image, so this is the belt-and-suspenders
# third copy, in pnpm's most universally-read config file.
only-built-dependencies[]=esbuild
only-built-dependencies[]=onnxruntime-node
only-built-dependencies[]=protobufjs
only-built-dependencies[]=sharp
only-built-dependencies[]=tesseract.js
